# PROTOCOL must be http (local development host or reverse-proxied server) or https.
PROTOCOL=__placeholder__
# AUTH_CODE must be 3 characters long.
AUTH_CODE=__placeholder__
TESTARO_AGENT=testaro-agent
# TESTARO_AGENT_PW must be identical to NETWATCH_AUTH in the Testaro .env.
TESTARO_AGENT_PW=__placeholder__
# Alert email configuration.
MANAGER_EMAIL=__placeholder__
SMTP_HOST=__placeholder__
SMTP_PORT=587
SMTP_USER=__placeholder__
SMTP_PASS=__placeholder__
# Alert thresholds.
WAVE_BALANCE_THRESHOLD=100
ANTHROPIC_BALANCE_THRESHOLD=5
# Per-token prices in dollars (Haiku 4.5: $0.80/MTok input, $4/MTok output).
ANTHROPIC_INPUT_PRICE=0.0000008
ANTHROPIC_OUTPUT_PRICE=0.000004
